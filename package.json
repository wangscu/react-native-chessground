{
  "name": "react-native-chessground",
  "version": "0.1.0",
  "description": "A React Native chessboard component ported from chessground",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "react-native": "src/index.tsx",
  "types": "lib/typescript/index.d.ts",
  "files": [
    "src",
    "lib",
    "assets"
  ],
  "scripts": {
    "test": "vitest run __tests__/",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "prepare": "bob build",
    "e2e:android:build": "cd example/android && ./gradlew assembleRelease",
    "e2e:android:test": "maestro test e2e/flows/smoke.yaml",
    "e2e:android": "npm run e2e:android:build && npm run e2e:android:test"
  },
  "keywords": [
    "react-native",
    "chess",
    "chessboard",
    "lichess"
  ],
  "license": "GPL-3.0",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0",
    "react-native-gesture-handler": ">=2.0.0",
    "react-native-reanimated": ">=3.17.0",
    "react-native-svg": ">=13.0.0"
  },
  "devDependencies": {
    "2": "^0.0.1-security",
    "@testing-library/react-native": "^13.0.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.0.0",
    "@types/react-test-renderer": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "jest": "^29.7.0",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-builder-bob": "^0.42.1",
    "react-test-renderer": "19.2.3",
    "ts-jest": "^29.4.11",
    "typescript": "~5.8.0",
    "vitest": "^4.1.8"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.json"
        }
      ]
    ]
  },
  "dependencies": {
    "buffer": "^6.0.3"
  }
}
