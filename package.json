{
  "name": "react-native-chessground",
  "version": "0.1.0",
  "description": "A React Native chessboard component ported from chessground",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "source": "src/index.tsx",
  "files": [
    "src",
    "lib",
    "assets"
  ],
  "scripts": {
    "test": "vitest run __tests__/",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "prepare": "bob build"
  },
  "keywords": [
    "react-native",
    "chess",
    "chessboard",
    "lichess"
  ],
  "license": "GPL-3.0",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0",
    "react-native-gesture-handler": ">=2.0.0",
    "react-native-reanimated": ">=3.0.0",
    "react-native-svg": ">=13.0.0"
  },
  "devDependencies": {
    "2": "^0.0.1-security",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.0.0",
    "@types/react-test-renderer": "^19.1.0",
    "@vitest/coverage-v8": "^4.1.8",
    "jest": "^29.7.0",
    "react": "^18.0.0",
    "react-native": "^0.74.0",
    "react-native-builder-bob": "^0.42.1",
    "react-native-gesture-handler": "^2.0.0",
    "react-native-reanimated": "^3.0.0",
    "react-native-svg": "^15.0.0",
    "react-test-renderer": "^18.3.1",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.json"
        }
      ]
    ]
  }
}
